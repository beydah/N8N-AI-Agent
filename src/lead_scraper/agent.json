      "name": "Filter Phone",
      "retryOnFail": false,
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// 1. Get existing database rows (from Google Sheets)\nconst existingItems = $('Get Table').all();\nif (!Array.isArray(existingItems)) {\n  throw new Error(\"Error: Could not retrieve Google Sheets data.\");\n}\n\n// 2. Extract existing IDs to check for duplicates\nconst seenIds = new Set(\n  existingItems\n    .map(item => item?.json?.ID ?? item?.json?.id)\n    .filter(Boolean)\n);\n\n// 3. Get new scraped places\nconst places = $('Aggregate Page').first()?.json?.places;\nif (!Array.isArray(places)) {\n  throw new Error(\"Error: No places array found in Aggregate node.\");\n}\n\n// 4. Get location coordinates for distance validation\nconst center = $('Maps Location').first()?.json?.results?.[0]?.geometry?.location;\nconst centerLat = center?.lat;\nconst centerLng = center?.lng;\n\nif (typeof centerLat !== 'number' || typeof centerLng !== 'number') {\n  throw new Error(\"Error: Could not retrieve coordinates from Maps Location node.\");\n}\n\nconst MAX_DISTANCE_KM = 25;\nconst EARTH_RADIUS_KM = 6371;\nconst toRad = deg => deg * Math.PI / 180;\n\n// Generic title case helper\nfunction toTitleCase(text) {\n  return text\n    ? text\n        .toLowerCase()\n        .split(/\\s+/)\n        .map(word => word.charAt(0).toUpperCase() + word.slice(1))\n        .join(' ')\n    : null;\n}\n\n// Haversine distance calculator\nfunction getDistanceKm(lat, lng) {\n  const dLat = toRad(lat - centerLat);\n  const dLng = toRad(lng - centerLng);\n\n  const a =\n    Math.sin(dLat / 2) ** 2 +\n    Math.cos(toRad(centerLat)) *\n      Math.cos(toRad(lat)) *\n      Math.sin(dLng / 2) ** 2;\n\n  return 2 * EARTH_RADIUS_KM * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));\n}\n\nconst result = [];\n\nfor (const place of places) {\n  const placeId = place?.id;\n  if (!placeId || seenIds.has(placeId)) continue;\n\n  const location = place?.location;\n  const lat = location?.latitude ?? location?.lat;\n  const lng = location?.longitude ?? location?.lng;\n\n  if (typeof lat !== 'number' || typeof lng !== 'number') continue;\n  if (getDistanceKm(lat, lng) > MAX_DISTANCE_KM) continue;\n\n  result.push({\n    json: {\n      id: placeId,\n      name: toTitleCase(place?.displayName?.text)\n    },\n    pairedItem: { item: 0 }\n  });\n\n  seenIds.add(placeId);\n}\n\nreturn result;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1792,
