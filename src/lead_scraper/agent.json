      "id": "7547d1ae-ab67-4f79-8f61-61fd6bf85964",
      "name": "Get Unique",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "// Map unique results\nconst uniqueMap = new Map(\n  $('Get Unique')\n    .all()\n    .map(item => [item.json?.id, item.json ?? {}])\n);\n\n// Normalize phone to digits-only\nconst normalizePhone = (phone) =>\n  phone ? String(phone).replace(/\\D/g, '') : '';\n\n// Generic phone validation: must be non-empty and look like a valid phone number\nconst isValidPhone = (phone) => {\n  if (!phone) return false;\n  const digits = normalizePhone(phone);\n  return digits.length >= 7;\n};\n\n// Generic title casing helper\nfunction toTitleCase(text) {\n  if (!text) return text;\n  return text\n    .toLowerCase()\n    .split(/\\s+/)\n    .map(word => word.charAt(0).toUpperCase() + word.slice(1))\n    .join(' ');\n}\n\nconst resultItems = [];\n\nfor (let index = 0; index < items.length; index++) {\n  const item = items[index];\n  const result = item.json?.result ?? {};\n\n  const scrapedPhone = result.formatted_phone_number ?? null;\n  const placeId = result.place_id ?? null;\n  const url = result.url ?? null;\n\n  if (!scrapedPhone || !isValidPhone(scrapedPhone)) continue;\n\n  const uniqueJson = uniqueMap.get(placeId) ?? {};\n  const tablePhone = uniqueJson.Phone ?? item.json?.Phone ?? null;\n\n  if (tablePhone && normalizePhone(scrapedPhone) === normalizePhone(tablePhone)) continue;\n\n  const rawName = uniqueJson.name ?? null;\n  const fixedName = toTitleCase(rawName);\n\n  resultItems.push({\n    json: {\n      id: uniqueJson.id ?? placeId ?? null,\n      name: fixedName,\n      phone: scrapedPhone,\n      url\n    },\n    pairedItem: item.pairedItem ?? { item: index }\n  });\n}\n\nreturn resultItems.length ? resultItems : [{ json: { empty: true } }];"
      },
