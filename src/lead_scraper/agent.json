color: var(--color-submit-btn-bg);\n\t}\n\n\t.btn-new-record {\n\t\tdisplay: inline-flex;\n\t\talign-items: center;\n\t\tjustify-content: center;\n\t\tbackground-color: var(--color-submit-btn-bg);\n\t\tcolor: var(--color-submit-btn-text);\n\t\ttext-decoration: none;\n\t\theight: var(--submit-btn-height);\n\t\tpadding: 0 24px;\n\t\tborder-radius: var(--border-radius-input);\n\t\tfont-size: var(--font-size-paragraph);\n\t\tfont-weight: var(--font-weight-bold);\n\t\ttransition: opacity 0.2s ease, transform 0.1s ease;\n\t\twidth: 100%;\n\t\tbox-sizing: border-box;\n\t\tmargin-bottom: 20px;\n\t}\n\n\t.btn-new-record:hover {\n\t\topacity: 0.9;\n\t\ttransform: translateY(-1px);\n\t}\n\t\n\t.btn-new-record:active {\n\t\ttransform: translateY(1px);\n\t}\n\n\t.link-secondary {\n\t\tdisplay: inline-block;\n\t\tcolor: var(--color-success-green);\n\t\tfont-size: var(--font-size-link);\n\t\tfont-weight: var(--font-weight-bold);\n\t\ttext-decoration: none;\n\t\ttransition: opacity 0.2s ease;\n\t}\n\n\t.link-secondary:hover {\n\t\topacity: 0.8;\n\t\ttext-decoration: underline;\n\t}\n\n\t.signature-wrapper {\n\t\tmargin-top: 32px;\n\t\tpadding-top: 16px;\n\t\tborder-top: 1px solid var(--color-card-border);\n\t\tcolor: var(--color-signature-text);\n\t\tfont-size: var(--font-size-signature);\n\t}\n\n\t.signature-link {\n\t\tcolor: var(--color-signature-link);\n\t\tfont-weight: var(--font-weight-bold);\n\t\ttext-decoration: none;\n\t\ttransition: opacity 0.2s ease;\n\t}\n\n\t.signature-link:hover {\n\t\topacity: 0.8;\n\t\ttext-decoration: underline;\n\t}\n</style>\n\n<div class=\"custom-success-page\">\n\t<div class=\"success-card\">\n\t\t<div class=\"icon-wrapper\">🚀</div>\n\t\t<h2 class=\"title\">Process Completed!</h2>\n\t\t<p class=\"message\">\n\t\t\t<span class=\"highlight\">{{ $json.count }}</span> new records for <span class=\"highlight\">{{ $('Variable').item.json.Location }} - {{ $('Variable').item.json.Keyword }}</span> have been successfully added to the database.\n\t\t</p>